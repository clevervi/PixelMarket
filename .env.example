# ==============================
# Supabase (required)
# ==============================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only (never expose publicly)
SUPABASE_SERVICE_ROLE_KEY=

# ==============================
# Database (required for pg-based repositories)
# ==============================
# Prefer a single connection string (Supabase Settings → Database → Connection string)
SUPABASE_DB_URL=
# Alternative (Vercel Postgres / other providers)
DATABASE_URL=

# If you use individual fields instead of a connection string:
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=postgres

# Optional pool / SSL settings
DB_POOL_MAX=10
# Force SSL on/off if needed (true/false)
DB_SSL=true

# ==============================
# Internal auth cookie (required)
# ==============================
# Secret used to sign the httpOnly auth_token cookie
AUTH_SECRET=
